# Reddit API credentials (free). Copy this file to ".env" and fill in.
# Get them at https://www.reddit.com/prefs/apps  ->  "create another app..."
#   - type: script
#   - redirect uri: http://localhost:8080  (unused, but required)
# After creating, the CLIENT_ID is the string under the app name;
# the CLIENT_SECRET is labeled "secret".
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=rally-radar/1.0 by u/yourusername
